FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies with force flag for React 19 compatibility
RUN npm install --force

# Copy the rest of the application
COPY . .

# Clear Next.js cache to prevent corrupted cache issues
RUN rm -rf .next

# Expose port
EXPOSE 3000

# Start development server
CMD ["npm", "run", "dev"]